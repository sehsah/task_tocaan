{
  "info": {
    "_postman_id": "order-payment-api-collection",
    "name": "Order & Payment Management API",
    "description": "RESTful API for managing orders and payments with JWT authentication and strategy-pattern payment gateways.\n\n## Setup\n1. Set the `base_url` variable to your API base URL (e.g. `http://localhost:8000`)\n2. Register a user and login to get a JWT token\n3. The token is automatically captured into the `auth_token` variable\n4. All protected endpoints use `Bearer {{auth_token}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/register", "host": ["{{base_url}}"], "path": ["api", "auth", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["if (pm.response.code === 201) { pm.collectionVariables.set('auth_token', pm.response.json().token); }"],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "Success - 201",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}" },
                "url": { "raw": "{{base_url}}/api/auth/register" }
              },
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"User registered successfully.\",\n  \"user\": {\n    \"id\": 1,\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"created_at\": \"2024-01-01T00:00:00+00:00\"\n  },\n  \"token\": \"eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...\",\n  \"type\": \"bearer\"\n}"
            },
            {
              "name": "Validation Error - 422",
              "originalRequest": { "method": "POST", "body": { "mode": "raw", "raw": "{}" } },
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"message\": \"The name field is required.\",\n  \"errors\": {\n    \"name\": [\"The name field is required.\"],\n    \"email\": [\"The email field is required.\"],\n    \"password\": [\"The password field is required.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": ["if (pm.response.code === 200) { pm.collectionVariables.set('auth_token', pm.response.json().token); }"],
                "type": "text/javascript"
              }
            }
          ],
          "response": [
            {
              "name": "Success - 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Login successful.\",\n  \"user\": { \"id\": 1, \"name\": \"John Doe\", \"email\": \"john@example.com\" },\n  \"token\": \"eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...\",\n  \"type\": \"bearer\"\n}"
            },
            {
              "name": "Invalid Credentials - 401",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"message\": \"Invalid credentials.\"\n}"
            }
          ]
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/me", "host": ["{{base_url}}"], "path": ["api", "auth", "me"] }
          },
          "response": [
            {
              "name": "Success - 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"user\": { \"id\": 1, \"name\": \"John Doe\", \"email\": \"john@example.com\", \"created_at\": \"2024-01-01T00:00:00+00:00\" }\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/auth/logout", "host": ["{{base_url}}"], "path": ["api", "auth", "logout"] }
          },
          "response": [
            {
              "name": "Success - 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Logged out successfully.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/orders?status=pending&per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "orders"],
              "query": [
                { "key": "status", "value": "pending", "description": "Filter by status: pending | confirmed | cancelled" },
                { "key": "per_page", "value": "15", "description": "Items per page (default: 15)" }
              ]
            }
          },
          "response": [
            {
              "name": "Success - 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": [\n    {\n      \"id\": 1,\n      \"user_id\": 1,\n      \"status\": \"pending\",\n      \"total\": 45.00,\n      \"notes\": \"Please handle with care\",\n      \"items\": [\n        { \"id\": 1, \"product_name\": \"Widget A\", \"quantity\": 2, \"price\": 10.00, \"subtotal\": 20.00 },\n        { \"id\": 2, \"product_name\": \"Widget B\", \"quantity\": 1, \"price\": 25.00, \"subtotal\": 25.00 }\n      ],\n      \"created_at\": \"2024-01-01T00:00:00+00:00\",\n      \"updated_at\": \"2024-01-01T00:00:00+00:00\"\n    }\n  ],\n  \"links\": { \"first\": \"...\", \"last\": \"...\", \"prev\": null, \"next\": null },\n  \"meta\": { \"current_page\": 1, \"from\": 1, \"last_page\": 1, \"per_page\": 15, \"to\": 1, \"total\": 1 }\n}"
            },
            {
              "name": "Unauthenticated - 401",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"message\": \"Unauthenticated.\"\n}"
            }
          ]
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"pending\",\n  \"notes\": \"Please handle with care\",\n  \"items\": [\n    { \"product_name\": \"Widget A\", \"quantity\": 2, \"price\": 10.00 },\n    { \"product_name\": \"Widget B\", \"quantity\": 1, \"price\": 25.00 }\n  ]\n}"
            },
            "url": { "raw": "{{base_url}}/api/orders", "host": ["{{base_url}}"], "path": ["api", "orders"] }
          },
          "response": [
            {
              "name": "Success - 201",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Order created successfully.\",\n  \"data\": {\n    \"id\": 1,\n    \"user_id\": 1,\n    \"status\": \"pending\",\n    \"total\": 45.00,\n    \"notes\": \"Please handle with care\",\n    \"items\": [\n      { \"id\": 1, \"product_name\": \"Widget A\", \"quantity\": 2, \"price\": 10.00, \"subtotal\": 20.00 },\n      { \"id\": 2, \"product_name\": \"Widget B\", \"quantity\": 1, \"price\": 25.00, \"subtotal\": 25.00 }\n    ],\n    \"created_at\": \"2024-01-01T00:00:00+00:00\",\n    \"updated_at\": \"2024-01-01T00:00:00+00:00\"\n  }\n}"
            },
            {
              "name": "Validation Error - 422",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"message\": \"The items field is required.\",\n  \"errors\": {\n    \"items\": [\"The items field is required.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/1", "host": ["{{base_url}}"], "path": ["api", "orders", "1"] }
          },
          "response": [
            {
              "name": "Success - 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"id\": 1,\n    \"user_id\": 1,\n    \"status\": \"pending\",\n    \"total\": 45.00,\n    \"notes\": \"Please handle with care\",\n    \"items\": [...],\n    \"payments\": [],\n    \"created_at\": \"2024-01-01T00:00:00+00:00\"\n  }\n}"
            },
            {
              "name": "Not Found - 404",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"message\": \"No query results for model [App\\\\Models\\\\Order] 999\"\n}"
            }
          ]
        },
        {
          "name": "Update Order",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\",\n  \"notes\": \"Updated notes\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/orders/1", "host": ["{{base_url}}"], "path": ["api", "orders", "1"] }
          },
          "response": [
            {
              "name": "Success - 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Order updated successfully.\",\n  \"data\": { \"id\": 1, \"status\": \"confirmed\", ... }\n}"
            }
          ]
        },
        {
          "name": "Delete Order",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/1", "host": ["{{base_url}}"], "path": ["api", "orders", "1"] }
          },
          "response": [
            {
              "name": "Success - 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Order deleted successfully.\"\n}"
            },
            {
              "name": "Has Payments - 422",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"message\": \"Cannot delete an order that has associated payments.\"\n}"
            }
          ]
        },
        {
          "name": "Get Payments for Order",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/orders/1/payments", "host": ["{{base_url}}"], "path": ["api", "orders", "1", "payments"] }
          },
          "response": [
            {
              "name": "Success - 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": [\n    {\n      \"id\": 1,\n      \"order_id\": 1,\n      \"payment_method\": \"stripe\",\n      \"status\": \"successful\",\n      \"gateway_response\": { \"gateway\": \"stripe\", \"transaction_id\": \"STR-ABC123\", \"status\": \"successful\" },\n      \"processed_at\": \"2024-01-01T00:00:00+00:00\"\n    }\n  ],\n  \"meta\": { \"current_page\": 1, \"total\": 1 }\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Process Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": 1,\n  \"payment_method\": \"stripe\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/payments", "host": ["{{base_url}}"], "path": ["api", "payments"] }
          },
          "response": [
            {
              "name": "Success - 201 (Stripe)",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Payment processed.\",\n  \"data\": {\n    \"id\": 1,\n    \"order_id\": 1,\n    \"payment_method\": \"stripe\",\n    \"status\": \"successful\",\n    \"gateway_response\": {\n      \"gateway\": \"stripe\",\n      \"status\": \"successful\",\n      \"transaction_id\": \"STR-64AB1234\",\n      \"message\": \"Stripe payment authorised and captured.\",\n      \"processed_at\": \"2024-01-01T00:00:00+00:00\"\n    },\n    \"processed_at\": \"2024-01-01T00:00:00+00:00\",\n    \"created_at\": \"2024-01-01T00:00:00+00:00\"\n  }\n}"
            },
            {
              "name": "Success - 201 (Credit Card - even total)",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Payment processed.\",\n  \"data\": {\n    \"id\": 2,\n    \"order_id\": 2,\n    \"payment_method\": \"credit_card\",\n    \"status\": \"successful\",\n    \"gateway_response\": {\n      \"gateway\": \"credit_card\",\n      \"status\": \"successful\",\n      \"transaction_id\": \"CC-64AB5678\",\n      \"message\": \"Credit card payment processed successfully.\"\n    }\n  }\n}"
            },
            {
              "name": "Order Not Confirmed - 422",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"message\": \"Payment can only be processed for orders in [confirmed] status. Current status: [pending].\"\n}"
            },
            {
              "name": "Unsupported Gateway - 422",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"message\": \"The selected payment method is not supported. Supported methods: credit_card, paypal, stripe.\",\n  \"errors\": {\n    \"payment_method\": [\"The selected payment method is not supported...\"]\n  }\n}"
            },
            {
              "name": "Order Not Found - 422",
              "status": "Unprocessable Entity",
              "code": 422,
              "body": "{\n  \"message\": \"The selected order id is invalid.\",\n  \"errors\": {\n    \"order_id\": [\"The selected order id is invalid.\"]\n  }\n}"
            }
          ]
        },
        {
          "name": "List All Payments",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/payments?per_page=15",
              "host": ["{{base_url}}"],
              "path": ["api", "payments"],
              "query": [{ "key": "per_page", "value": "15" }]
            }
          },
          "response": [
            {
              "name": "Success - 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": [\n    {\n      \"id\": 1,\n      \"order_id\": 1,\n      \"payment_method\": \"stripe\",\n      \"status\": \"successful\",\n      \"gateway_response\": { ... },\n      \"processed_at\": \"2024-01-01T00:00:00+00:00\"\n    }\n  ],\n  \"meta\": { \"current_page\": 1, \"total\": 1, \"per_page\": 15 }\n}"
            }
          ]
        },
        {
          "name": "Get Payment",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{auth_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/payments/1", "host": ["{{base_url}}"], "path": ["api", "payments", "1"] }
          },
          "response": [
            {
              "name": "Success - 200",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"data\": {\n    \"id\": 1,\n    \"order_id\": 1,\n    \"payment_method\": \"paypal\",\n    \"status\": \"successful\",\n    \"gateway_response\": {\n      \"gateway\": \"paypal\",\n      \"status\": \"successful\",\n      \"transaction_id\": \"PP-64AB9012\",\n      \"message\": \"PayPal payment completed successfully.\"\n    },\n    \"processed_at\": \"2024-01-01T00:00:00+00:00\"\n  }\n}"
            },
            {
              "name": "Not Found - 404",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"message\": \"No query results for model [App\\\\Models\\\\Payment] 999\"\n}"
            }
          ]
        }
      ]
    }
  ]
}
